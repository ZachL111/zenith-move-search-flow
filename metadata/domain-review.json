{
  "repo": "zenith-move-search-flow",
  "language": "Elixir",
  "category": "Chess and game engines",
  "goal": "Build an Elixir toolkit that studies search behavior through append-only fixtures, with checkpoint recovery checks and bounded memory input sets.",
  "review_model": {
    "terms": [
      "position pressure",
      "move ordering",
      "search width",
      "endgame risk"
    ],
    "lanes": [
      "ship",
      "watch",
      "hold"
    ],
    "score": "signal * 2 + slack + confidence - drag * 3",
    "purpose": "surface the domain-specific cases that need the most careful review"
  },
  "cases": [
